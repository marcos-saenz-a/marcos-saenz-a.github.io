---
import { Image } from 'astro:assets';
import heroImage from '../assets/marcos-saenz-portafolio.png';

import jsIcon from '../assets/floating/js.svg';
import dockerIcon from '../assets/floating/docker.svg';
import pythonIcon from '../assets/floating/python.svg';
import gcpIcon from '../assets/floating/gcp.svg';
import sqlIcon from '../assets/floating/sql.svg';
import githubIcon from '../assets/floating/github.svg';
import n8nIcon from '../assets/floating/n8n.svg';
import ubuntuIcon from '../assets/floating/ubuntu.svg';

const techIcons = [
  {
    icon: jsIcon,
    alt: "JavaScript",
    position: "top-1/4 left-1/12",
    rotation: "rotate-[-10deg]",
    animation: "animate-[bounce_5s_infinite]"
  },
  {
    icon: dockerIcon,
    alt: "Docker",
    position: "bottom-1/12 left-1/7",
    rotation: "rotate-[-6deg]",
    animation: "animate-[bounce_7s_infinite_0.2s]"
  },
  {
    icon: pythonIcon,
    alt: "Python",
    position: "top-10 right-1/6",
    rotation: "rotate-12",
    animation: "animate-[bounce_8s_infinite_1s]"
  },
  {
    icon: gcpIcon,
    alt: "Google Cloud",
    position: "top-1/16 left-1/4",
    rotation: "rotate-[-8deg]",
    animation: "animate-[bounce_6s_infinite_0.8s]"
  },
  {
    icon: sqlIcon,
    alt: "SQL",
    position: "bottom-1/3 left-1/8",
    rotation: "rotate-10",
    animation: "animate-[bounce_6s_infinite_0.5s]"
  },
  {
    icon: githubIcon,
    alt: "GitHub",
    position: "top-1/2 right-1/8",
    rotation: "rotate-[-5deg]",
    animation: "animate-[bounce_7s_infinite_0.7s]"
  },
  {
    icon: n8nIcon,
    alt: "n8n",
    position: "top-2 right-1/4",
    rotation: "rotate-[5deg]",
    animation: "animate-[bounce_7s_infinite_0.7s]"
  },
  {
    icon: ubuntuIcon,
    alt: "Ubuntu",
    position: "bottom-10 right-1/10",
    rotation: "rotate-[5deg]",
    animation: "animate-[bounce_7s_infinite_0.7s]"
  }
];
---
<section id="inicio" class="min-h-screen pt-20 pb-10 flex flex-col justify-center relative overflow-hidden">
    <div class="absolute top-4 right-4 flex gap-4">
        <a href="https://api.whatsapp.com/send?phone=522227958793&text=Hola%20Marcos,%20vi%20tu%20portafolio%20y%20me%20gustaría%20ponerme%20en%20contacto." target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-[#1a1a2e] border border-slate-700 rounded-lg text-sm text-slate-300 hover:text-white transition-colors" aria-label="Contactar por WhatsApp">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.9 11.9 0 0012 0C5.373 0 .053 5.32.053 11.947c0 2.103.547 4.162 1.59 5.99L0 24l6.285-1.63A11.9 11.9 0 0012 24c6.627 0 11.947-5.32 11.947-11.947 0-3.19-1.244-6.18-3.427-8.573zM12 21.5c-1.77 0-3.51-.46-5.02-1.33l-.36-.21-3.73.97.99-3.63-.24-.37A9.46 9.46 0 012.55 11.95C2.55 7.09 6.14 3.5 11 3.5c2 0 3.9.78 5.32 2.2 1.4 1.4 2.2 3.33 2.2 5.3 0 5.36-4.63 9.48-9.52 9.48z"></path></svg>
            WhatsApp
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-400 text-xs font-medium mb-6">
                <span class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
                INGENIERO EN TICs
            </div>
            
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
                Soluciones <span class="text-transparent bg-clip-text bg-linear-to-r from-purple-400 to-blue-500">tecnológicas</span><br /><span id="typing-text"></span><span class="typing-cursor text-slate-300">|</span>.
            </h1>
            
            <p class="text-lg text-slate-400 mb-8 max-w-xl leading-relaxed">
                Ingeniero en Tecnologías de la Información y Comunicaciones con experiencia en infraestructura, automatización y desarrollo web. Especializado en diseñar e implementar soluciones TI escalables, desde redes y servidores hasta aplicaciones web modernas.
            </p>
            
            <div class="flex flex-wrap gap-4">
                <a href="#proyectos" class="px-6 py-3 rounded-lg bg-linear-to-r from-purple-600 to-blue-600 text-white font-medium hover:from-purple-500 hover:to-blue-500 transition-all shadow-[0_0_20px_rgba(124,58,237,0.3)]">
                    Ver mi trabajo
                </a>
                <a href="/Marcos-Saenz-CV.pdf" download="Marcos-Saenz-CV.pdf" target="_blank" rel="noopener noreferrer" class="px-6 py-3 rounded-lg border border-slate-700 text-slate-300 font-medium hover:bg-slate-800 hover:text-white transition-all flex items-center gap-2">
                    Descargar CV
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                </a>
            </div>
        </div>

        <div class="relative flex justify-center items-center">
            <div class="absolute w-[65%] max-w-[320px] aspect-square rounded-full border border-purple-500/20 rotate-60 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
            <div class="absolute w-[85%] max-w-[420px] aspect-square rounded-full border border-purple-500/20 rotate-60 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
            <div class="absolute w-[110%] max-w-[520px] aspect-square rounded-full border border-blue-500/10 rotate-[-30deg] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
            {
                techIcons.map((item) => (
                    <div class={`absolute z-0 ${item.position} ${item.rotation} ${item.animation}`}>
                        <Image 
                            src={item.icon} 
                            alt={item.alt}
                            width={48}
                            height={48}
                            loading="eager"
                            class="w-10 h-10 md:w-12 md:h-12"
                        />
                    </div>
                ))
            }
            
            <div class="relative w-64 h-64 md:w-80 md:h-80 z-10">
                <div class="w-full h-full relative overflow-hidden flex items-center justify-center">
                    <Image src={heroImage} loading="eager" alt="Marcos Saenz Avatar" class="w-full h-full object-cover object-center" style="mask-image: linear-gradient(to bottom, black 95%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 95%, transparent 100%);" onerror="this.src='https://api.dicebear.com/7.x/avataaars/svg?seed=Marcos&backgroundColor=1a1a2e&scale=80'" aria-hidden="false"/>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .typing-cursor {
        animation: blink 0.7s infinite;
    }

    @keyframes blink {
        50% {
            opacity: 0;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const typingTextElement = document.getElementById('typing-text');
        if (!typingTextElement) return;

        const words = ["innovadoras", "escalables", "eficientes", "seguras"];
        let wordIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        const typingSpeed = 150;
        const deletingSpeed = 75;
        const delayBetweenWords = 2000;

        function type() {
            const currentWord = words[wordIndex];
            
            if (isDeleting) {
                typingTextElement.textContent = currentWord.substring(0, charIndex - 1);
                charIndex--;
            } else {
                typingTextElement.textContent = currentWord.substring(0, charIndex + 1);
                charIndex++;
            }

            if (!isDeleting && charIndex === currentWord.length) {
                setTimeout(() => isDeleting = true, delayBetweenWords);
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                wordIndex = (wordIndex + 1) % words.length;
            }

            setTimeout(type, isDeleting ? deletingSpeed : typingSpeed);
        }

        type();
    });
</script>