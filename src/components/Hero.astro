---
---
<section id="inicio" class="min-h-screen pt-20 pb-10 flex flex-col justify-center relative">
    <div class="absolute top-4 right-4 flex gap-4">
        <a href="#" class="flex items-center gap-2 px-4 py-2 bg-[#1a1a2e] border border-slate-700 rounded-lg text-sm text-slate-300 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
            Descargar CV
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-400 text-xs font-medium mb-6">
                <span class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
                INGENIERO EN TI
            </div>
            
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
                Soluciones <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-500">tecnológicas e infraestructura</span> escalable.
            </h1>
            
            <p class="text-lg text-slate-400 mb-8 max-w-xl leading-relaxed">
                Ingeniero en Tecnologías de la Información con experiencia en infraestructura, automatización y desarrollo web. Especializado en diseñar e implementar soluciones TI escalables, desde redes y servidores hasta aplicaciones web modernas.
            </p>
            
            <div class="flex flex-wrap gap-4">
                <a href="#proyectos" class="px-6 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium hover:from-purple-500 hover:to-blue-500 transition-all shadow-[0_0_20px_rgba(124,58,237,0.3)]">
                    Ver mi trabajo
                </a>
                <a href="#sobre-mi" class="px-6 py-3 rounded-lg border border-slate-700 text-slate-300 font-medium hover:bg-slate-800 hover:text-white transition-all flex items-center gap-2">
                    Conocer más
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                </a>
            </div>
        </div>

        <div class="relative flex justify-center items-center">
            <!-- decorative circles -->
            <div class="absolute w-[120%] aspect-square rounded-full border border-purple-500/20 rotate-[60deg] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
            <div class="absolute w-[140%] aspect-square rounded-full border border-blue-500/10 rotate-[-30deg] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
            
            <!-- avatar (Placeholder for now) -->
            <div class="relative w-64 h-64 md:w-80 md:h-80 z-10">
                <div class="absolute inset-0 bg-gradient-to-b from-purple-500/20 to-transparent rounded-b-3xl"></div>
                <!-- Need an avatar image, using placeholder avatar style since none is available -->
                <div class="w-full h-full bg-[#1a1a2e] rounded-b-3xl border border-slate-700/50 relative overflow-hidden flex flex-col items-center justify-end">
                    <img src="/img/marcos-saenz-portfolio.png" alt="Marcos Saenz Avatar" class="w-full object-cover scale-110" onerror="this.src='https://api.dicebear.com/7.x/avataaars/svg?seed=Marcos&backgroundColor=1a1a2e&scale=80'"/>
                </div>
            </div>

            <!-- floating tech icons -->
            <div class="absolute top-1/4 left-0 w-12 h-12 bg-[#1a1a2e] border border-slate-700 rounded-xl flex items-center justify-center text-yellow-400 rotate-[-10deg] animate-[bounce_5s_infinite]">
                <span class="font-bold">JS</span>
            </div>
            <div class="absolute bottom-1/4 right-0 w-12 h-12 bg-[#1a1a2e] border border-slate-700 rounded-xl flex items-center justify-center text-blue-400 rotate-[10deg] animate-[bounce_6s_infinite_0.5s]">
                <span class="font-bold">TS</span>
            </div>
            <div class="absolute top-10 right-10 w-10 h-10 bg-[#1a1a2e] border border-slate-700 rounded-full flex items-center justify-center text-purple-400 animate-[bounce_4s_infinite_1s]">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="mt-20 grid grid-cols-2 lg:grid-cols-4 gap-4 p-6 bg-[#11111a] border border-slate-800 rounded-2xl">
        <div class="flex items-center gap-4 border-r border-slate-800/0 lg:border-slate-800 pr-4">
            <div class="w-12 h-12 rounded-lg bg-slate-800/50 flex items-center justify-center text-purple-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <div class="text-2xl font-bold text-white">7+</div>
                <div class="text-xs text-slate-400 uppercase tracking-wider">Años de experiencia TI</div>
            </div>
        </div>
        <div class="flex items-center gap-4 lg:border-r border-slate-800 pr-4">
            <div class="w-12 h-12 rounded-lg bg-slate-800/50 flex items-center justify-center text-blue-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
                <div class="text-2xl font-bold text-white">20+</div>
                <div class="text-xs text-slate-400 uppercase tracking-wider">Proyectos ejecutados</div>
            </div>
        </div>
        <div class="flex items-center gap-4 border-r border-slate-800/0 lg:border-slate-800 pr-4">
            <div class="w-12 h-12 rounded-lg bg-slate-800/50 flex items-center justify-center text-emerald-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
            </div>
            <div>
                <div class="text-2xl font-bold text-white">15+</div>
                <div class="text-xs text-slate-400 uppercase tracking-wider">Tecnologías dominadas</div>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-slate-800/50 flex items-center justify-center text-purple-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <div class="text-2xl font-bold text-white">100%</div>
                <div class="text-xs text-slate-400 uppercase tracking-wider">Compromiso</div>
            </div>
        </div>
    </div>
</section>