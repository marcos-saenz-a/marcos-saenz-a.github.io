---
const misCertificados = [
	{ titulo: "Google Cloud Computing Foundations", entidad: "Google Cloud", img: "/img/google-cloud-computing-foundations-certificate.png", link: "https://www.credly.com/badges/561ba8a3-b265-45aa-870e-6c867f2a3df2/public_url"},
	{ titulo: "Google AI Essentials", entidad: "Google", img: "/img/google-ai-essentials.png", link: "https://www.coursera.org/account/accomplishments/verify/V0FFVCZRR4E5"},
	{ titulo: "Learn Tailwind CSS", entidad: "Scrimba", img: "/img/learn-tailwind-css.png", link: "https://scrimba.com/@marcos-saenz-a:certs;cert2JbLs3qgBFHryrhmvMuRRrg6Pz3S2p4oqW1APe"},
	{ titulo: "Learn HTML and CSS", entidad: "Scrimba", img: "/img/learn-html-and-css.png", link: "https://scrimba.com/@marcos-saenz-a:certs;cert24zAwPPowRzHm9YSaqgbxnqyT1Xdr67U4C8tG"},
	{ titulo: "Learn JavaScript", entidad: "Scrimba", img: "/img/learn-javascript.png", link: "https://scrimba.com/@marcos-saenz-a:certs;cert24zAwPPowRzHm9YSaqgbxnsTk8pB1psk5RXs2"},
];
---

<section id="certificados" class="py-20 border-t border-slate-800/50">
    <div class="mb-12">
        <h2 class="text-xs font-bold tracking-widest text-slate-500 uppercase flex items-center gap-4 mb-2">
            <span class="w-8 h-px bg-slate-700"></span> CERTIFICADOS
        </h2>
        <h3 class="text-2xl font-bold text-white mb-8">Certificaciones y<br/>cursos importantes.</h3>
    </div>

    <div class="flex flex-col gap-4 columns-2">
        {misCertificados.map((cert) => (
            <div class="bg-[#11111a]/50 border border-slate-700 rounded-xl shadow-2xl shadow-purple-500/10 overflow-hidden">
                <button class="w-full text-left certificate-toggle p-4 flex justify-between items-center hover:bg-slate-800/50 transition-colors">
                    <div>
                        <h4 class="font-bold text-white">{cert.titulo}</h4>
                        <p class="text-sm text-slate-400">{cert.entidad}</p>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400 transition-transform duration-300 transform chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                <div class="expandable-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out">
                    <div class="overflow-hidden">
                        <div class="p-4 border-t border-slate-700">
                            <img src={cert.img} alt={`Certificado de ${cert.titulo}`} class="w-full h-auto rounded-md mb-4"/>
                            {cert.link && (
                                <div class="text-center">
                                    <a href={cert.link} target="_blank" rel="noopener noreferrer" class="text-sm text-purple-400 hover:underline">
                                        Verificar certificado
                                    </a>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const certificateToggles = document.querySelectorAll('.certificate-toggle');

        certificateToggles.forEach(toggle => {
            toggle.addEventListener('click', () => {
                const content = toggle.nextElementSibling;
                const chevron = toggle.querySelector('.chevron');

                // Close other open certificates to create an accordion effect
                document.querySelectorAll('.expandable-content.expanded').forEach(openContent => {
                    if (openContent !== content) {
                        openContent.classList.remove('expanded');
                        const openChevron = openContent.previousElementSibling.querySelector('.chevron');
                        if (openChevron) {
                            openChevron.classList.remove('rotate-180');
                        }
                    }
                });

                // Toggle current certificate
                content.classList.toggle('expanded');
                chevron.classList.toggle('rotate-180');
            });
        });
    });
</script>

<style>
    .expandable-content.expanded {
        grid-template-rows: 1fr;
    }
</style>