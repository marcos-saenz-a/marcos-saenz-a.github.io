---
const { titulo, entidad, imagen, link } = Astro.props;
---
<button 
    class="certificate-card group relative bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 text-sm text-slate-300 hover:border-purple-500/50 hover:text-white transition-all duration-300 flex items-center gap-2"
    data-image={imagen}
    data-link={link}
    data-title={titulo}
    data-entidad={entidad}
>
    <!-- Generic Certificate Icon -->
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
    </svg>
    <span class="truncate">{titulo}</span>
    <svg xmlns="http://w3.org" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="icono-externo">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
</button>