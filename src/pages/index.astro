---
import '../styles/global.css'
import Sidebar from '../components/Sidebar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import MiscSections from '../components/MiscSections.astro';
import Certificado from '../components/Certificado.astro';

// Datos de certificados del CV
const misCertificados = [
	{ titulo: "Google Cloud Computing Foundations Certificate", entidad: "Google Cloud", img: "/img/google-cloud-computing-foundations-certificate.png", link: "https://www.credly.com/badges/561ba8a3-b265-45aa-870e-6c867f2a3df2/public_url"},
	{ titulo: "Google AI Essentials", entidad: "Google", img: "/img/google-ai-essentials.jpeg", link: "#" },
	{ titulo: "Learn JavaScript", entidad: "Scrimba", img: "/img/learn-javascript.png", link: "#" },
	{ titulo: "Learn Tailwind CSS", entidad: "Scrimba", img: "/img/learn-tailwind-css.png", link: "#" },
	{ titulo: "Learn HTML and CSS", entidad: "Scrimba", img: "/img/learn-html-and-css.png", link: "#" },
];

---

<html lang="es" class="scroll-smooth bg-[#0d0d0d]">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Marcos Sáenz | Ingeniero en TI - Infraestructura & Automatización</title>
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
        
        <style>
            body { font-family: 'Inter', sans-serif; }
            h1, h2, h3, h4, h5, h6 { font-family: 'Poppins', sans-serif; }
            code, pre { font-family: 'Fira Code', monospace; }
        </style>
	</head>
	<body class="bg-[#0d0d0d] text-slate-300 font-sans antialiased selection:bg-purple-500/30 selection:text-white">
        
        <Sidebar />
        
        <!-- Main Content Area with padding for Sidebar -->
        <main class="ml-16 md:ml-20 min-h-screen">
            <div class="max-w-5xl mx-auto px-6 lg:px-12">
                
                <Hero />
                <About />
                <Experience />
                
                <!-- CERTIFICADOS -->
                <section id="certificados" class="py-20 border-t border-slate-800/50">
                    <div class="mb-12">
                        <h2 class="text-xs font-bold tracking-widest text-slate-500 uppercase flex items-center gap-4 mb-2">
                            <span class="w-8 h-[1px] bg-slate-700"></span> 5. CERTIFICADOS
                        </h2>
                        <h3 class="text-2xl font-bold text-white mb-8">Tus certificaciones y<br/>cursos importantes.</h3>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                        {misCertificados.map((cert) => (
                            <div class="transform scale-95 origin-top hover:scale-100 transition-transform">
                                <Certificado 
                                    titulo={cert.titulo} 
                                    entidad={cert.entidad} 
                                    imagen={cert.img}
                                    link={cert.link}
                                />
                            </div>
                        ))}
                    </div>
                </section>
                
                <Projects />
                <MiscSections />
                
                <!-- CONTACT SECTION -->
                <section id="contacto" class="py-20 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-8">
                    <div>
                        <h2 class="text-xs font-bold tracking-widest text-slate-500 uppercase flex items-center gap-4 mb-2">
                            <span class="w-8 h-[1px] bg-slate-700"></span> 8. CONTACTO
                        </h2>
                        <h3 class="text-2xl font-bold text-white mb-2">Formas fáciles de<br/>contactarte.</h3>
                    </div>
                    
                    <div>
                       <p class="text-sm text-slate-400 mb-4">Hablemos de oportunidades y proyectos</p>
                       <div class="flex gap-4">
                           <a href="https://github.com/marcos-saenz-a" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-purple-600 transition-colors" target="_blank" rel="noopener noreferrer">
                               <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
                           </a>
                           <a href="https://linkedin.com/in/marcos-saenz-a" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-blue-500 transition-colors" target="_blank" rel="noopener noreferrer">
                               <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                           </a>
                           <a href="mailto:marcos.saenz.a@outlook.com" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-emerald-500 transition-colors">
                               <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                           </a>
                       </div>
                    </div>
                </section>
                
            </div>
            
            <footer class="border-t border-slate-800/50 py-8 px-6 text-center text-xs text-slate-500 flex flex-col md:flex-row justify-between items-center">
                <p>Construido con Astro • Optimizado para velocidad • Totalmente responsive</p>
                <div class="mt-4 md:mt-0 flex gap-4 items-center">
                    <span>Despliegue en GitHub Pages</span>
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
                </div>
            </footer>
        </main>
	</body>
</html>